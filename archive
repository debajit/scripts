#!/usr/bin/env bash

#
# archive - Archive a directory or file
#
# SYNOPSIS
#   archive DIR_OR_FILE_NAME
#
# DESCRIPTION
#
#   Takes the given file or directory and generates a .tar.xz
#   file with a timestamp. The original file is not touched.
#
# EXAMPLES
#   archive wiki
#   => wiki--2020-07-13--12-34.tar.xz
#

source "notification.sh"

# Script to compress a file or directory to .tar.xz with maximum extreme compression
# Usage: ./archive <file_or_directory_path>

usage() {
    echo "Usage: $0 <file_or_directory_path>"
    echo "Example: $0 /path/to/mydir"
    echo "Example: $0 /path/to/myfile.txt"
    echo ""
    echo "Output will be named: <name>--YYYY-MM-DD--HH-MM.tar.xz"
    exit 1
}

die() {
    echo "Error: $1"
    exit 1
}

# Check if argument is provided
[[ $# == 1 ]] || usage

TARGET_PATH="$1"

# Check if file or directory exists
[[ -e "$TARGET_PATH" ]] || die "File or directory '$TARGET_PATH' does not exist"

# Get the base name and generate timestamp
BASE_NAME=$(basename "$TARGET_PATH")
TIMESTAMP=$(date +"%Y-%m-%d--%H-%M")
OUTPUT_NAME="${BASE_NAME}--${TIMESTAMP}.tar.xz"

echo "Compressing '$TARGET_PATH' to '$OUTPUT_NAME' with maximum extreme compression..."
echo "This may take a while depending on the size..."

# Create tar.xz archive with maximum extreme compression
# -c: create archive
# -J: use xz compression
# -f: specify filename
# -C: change to parent directory
# XZ_OPT: maximum extreme compression with all threads
XZ_OPT="-9e --threads=0" tar -cJf "$OUTPUT_NAME" -C "$(dirname "$TARGET_PATH")" "$(basename "$TARGET_PATH")"

[[ $? == 0 ]] || die "Failed to create archive"

echo "Successfully created: $OUTPUT_NAME"
echo "Original: $TARGET_PATH"
echo "Archive size: $(du -h "$OUTPUT_NAME" | cut -f1)"
